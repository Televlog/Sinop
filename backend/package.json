    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "openai": "^4.52.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "plaid": "^41.4.0",
    "speakeasy": "^2.0.0",
    "tesseract.js": "^5.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
